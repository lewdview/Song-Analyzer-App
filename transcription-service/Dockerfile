FROM node:20-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ffmpeg ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY . .

ENV NODE_ENV=production
ENV NODE_OPTIONS=--expose-gc
ENV WHISPER_PORT=3001
ENV WHISPER_MODEL=Xenova/whisper-tiny.en
ENV WHISPER_FALLBACK_MODELS=Xenova/whisper-tiny.en
ENV WHISPER_NUM_BEAMS=1
ENV WHISPER_QUANTIZED=true
ENV WHISPER_PRELOAD_ON_STARTUP=false
ENV WHISPER_MEMORY_SAVER_WINDOW_LENGTH_S=12
ENV WHISPER_MEMORY_SAVER_WINDOW_OVERLAP_S=0.5
ENV WHISPER_MEMORY_SAVER_RESET_EVERY_WINDOWS=4
ENV WHISPER_PLAIN_MODE_FILE_MB=6
ENV WHISPER_PLAIN_MODE_DURATION_S=210
ENV WHISPER_PROCESS_ISOLATION_FILE_MB=6
ENV WHISPER_PROCESS_ISOLATION_DURATION_S=210

EXPOSE 3001

CMD ["npm", "start"]
